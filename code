import tkinter as tk
from tkinter import messagebox
import sqlite3


# ---------------- DATABASE SETUP ----------------

conn = sqlite3.connect("customers.db")
cursor = conn.cursor()

cursor.execute("""
CREATE TABLE IF NOT EXISTS customers (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    name TEXT NOT NULL,
    phone TEXT NOT NULL,
    email TEXT NOT NULL
)
""")

conn.commit()


# ---------------- FUNCTIONS ----------------

def add_customer():
    name = name_entry.get().strip()
    phone = phone_entry.get().strip()
    email = email_entry.get().strip()

    if name == "" or phone == "" or email == "":
        messagebox.showwarning("Missing Information", "Please fill in all fields.")
        return

    cursor.execute(
        "INSERT INTO customers (name, phone, email) VALUES (?, ?, ?)",
        (name, phone, email)
    )
    conn.commit()

    messagebox.showinfo("Success", "Customer added successfully.")
    clear_fields()
    view_customers()


def view_customers():
    customer_list.delete(0, tk.END)

    cursor.execute("SELECT * FROM customers")
    customers = cursor.fetchall()

    for customer in customers:
        customer_list.insert(
            tk.END,
            f"ID: {customer[0]} | Name: {customer[1]} | Phone: {customer[2]} | Email: {customer[3]}"
        )


def search_customer():
    search_term = search_entry.get().strip()

    if search_term == "":
        messagebox.showwarning("Empty Search", "Please enter a name, phone, or email.")
        return

    customer_list.delete(0, tk.END)

    cursor.execute("""
        SELECT * FROM customers
        WHERE name LIKE ? OR phone LIKE ? OR email LIKE ?
    """, (f"%{search_term}%", f"%{search_term}%", f"%{search_term}%"))

    results = cursor.fetchall()

    if len(results) == 0:
        customer_list.insert(tk.END, "No customer found.")
    else:
        for customer in results:
            customer_list.insert(
                tk.END,
                f"ID: {customer[0]} | Name: {customer[1]} | Phone: {customer[2]} | Email: {customer[3]}"
            )


def update_customer():
    selected = customer_list.curselection()

    if not selected:
        messagebox.showwarning("No Selection", "Please select a customer to update.")
        return

    customer_text = customer_list.get(selected[0])

    if not customer_text.startswith("ID:"):
        messagebox.showwarning("Invalid Selection", "Please select a valid customer.")
        return

    customer_id = customer_text.split("|")[0].replace("ID:", "").strip()

    name = name_entry.get().strip()
    phone = phone_entry.get().strip()
    email = email_entry.get().strip()

    if name == "" or phone == "" or email == "":
        messagebox.showwarning("Missing Information", "Please fill in all fields before updating.")
        return

    cursor.execute("""
        UPDATE customers
        SET name = ?, phone = ?, email = ?
        WHERE id = ?
    """, (name, phone, email, customer_id))

    conn.commit()

    messagebox.showinfo("Updated", "Customer updated successfully.")
    clear_fields()
    view_customers()


def delete_customer():
    selected = customer_list.curselection()

    if not selected:
        messagebox.showwarning("No Selection", "Please select a customer to delete.")
        return

    customer_text = customer_list.get(selected[0])

    if not customer_text.startswith("ID:"):
        messagebox.showwarning("Invalid Selection", "Please select a valid customer.")
        return

    customer_id = customer_text.split("|")[0].replace("ID:", "").strip()

    confirm = messagebox.askyesno("Confirm Delete", "Are you sure you want to delete this customer?")

    if confirm:
        cursor.execute("DELETE FROM customers WHERE id = ?", (customer_id,))
        conn.commit()

        messagebox.showinfo("Deleted", "Customer deleted successfully.")
        clear_fields()
        view_customers()


def fill_fields(event):
    selected = customer_list.curselection()

    if not selected:
        return

    customer_text = customer_list.get(selected[0])

    if not customer_text.startswith("ID:"):
        return

    parts = customer_text.split("|")

    name = parts[1].replace("Name:", "").strip()
    phone = parts[2].replace("Phone:", "").strip()
    email = parts[3].replace("Email:", "").strip()

    clear_fields()

    name_entry.insert(0, name)
    phone_entry.insert(0, phone)
    email_entry.insert(0, email)


def clear_fields():
    name_entry.delete(0, tk.END)
    phone_entry.delete(0, tk.END)
    email_entry.delete(0, tk.END)


# ---------------- GUI SETUP ----------------

root = tk.Tk()
root.title("Customer Contact Manager")
root.geometry("750x500")


title_label = tk.Label(
    root,
    text="Customer Contact Manager",
    font=("Arial", 20, "bold")
)
title_label.pack(pady=10)


form_frame = tk.Frame(root)
form_frame.pack(pady=10)


tk.Label(form_frame, text="Name:", font=("Arial", 12)).grid(row=0, column=0, padx=5, pady=5)
name_entry = tk.Entry(form_frame, width=30, font=("Arial", 12))
name_entry.grid(row=0, column=1, padx=5, pady=5)


tk.Label(form_frame, text="Phone:", font=("Arial", 12)).grid(row=1, column=0, padx=5, pady=5)
phone_entry = tk.Entry(form_frame, width=30, font=("Arial", 12))
phone_entry.grid(row=1, column=1, padx=5, pady=5)


tk.Label(form_frame, text="Email:", font=("Arial", 12)).grid(row=2, column=0, padx=5, pady=5)
email_entry = tk.Entry(form_frame, width=30, font=("Arial", 12))
email_entry.grid(row=2, column=1, padx=5, pady=5)


button_frame = tk.Frame(root)
button_frame.pack(pady=10)


tk.Button(button_frame, text="Add Customer", command=add_customer, width=15).grid(row=0, column=0, padx=5)
tk.Button(button_frame, text="Update", command=update_customer, width=15).grid(row=0, column=1, padx=5)
tk.Button(button_frame, text="Delete", command=delete_customer, width=15).grid(row=0, column=2, padx=5)
tk.Button(button_frame, text="View All", command=view_customers, width=15).grid(row=0, column=3, padx=5)
tk.Button(button_frame, text="Clear Fields", command=clear_fields, width=15).grid(row=0, column=4, padx=5)


search_frame = tk.Frame(root)
search_frame.pack(pady=10)


tk.Label(search_frame, text="Search:", font=("Arial", 12)).grid(row=0, column=0, padx=5)
search_entry = tk.Entry(search_frame, width=35, font=("Arial", 12))
search_entry.grid(row=0, column=1, padx=5)

tk.Button(search_frame, text="Search Customer", command=search_customer, width=18).grid(row=0, column=2, padx=5)


customer_list = tk.Listbox(root, width=100, height=12, font=("Arial", 10))
customer_list.pack(pady=10)

customer_list.bind("<<ListboxSelect>>", fill_fields)


view_customers()

root.mainloop()


# Close database connection when app closes
conn.close()
